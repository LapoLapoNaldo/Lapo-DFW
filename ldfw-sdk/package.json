{
    "name": "ldfw-sdk",
    "displayName": "LDFW SDK",
    "description": "LDFW SDK — syntax highlighting, diagnostics e autocomplete para arquivos .ldfw (mais ferramentas em breve).",
    "version": "0.1.0",
    "publisher": "lapo",
    "private": true,
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "scripts": {
        "bundle:parser": "node -e \"require('fs').copyFileSync(require('path').join('..','ldfw','compiler','parser.js'),'parser.js')\"",
        "vscode:prepublish": "npm run bundle:parser"
    },
    "contributes": {
        "languages": [
            {
                "id": "ldfw",
                "aliases": [
                    "LDFW",
                    "ldfw"
                ],
                "extensions": [
                    ".ldfw"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "ldfw",
                "scopeName": "source.ldfw",
                "path": "./syntaxes/ldfw.tmLanguage.json"
            }
        ]
    },
    "main": "./extension.js"
}
