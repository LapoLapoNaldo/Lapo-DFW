//
// Extensions: {
//     DocColors {
//         light { primary: "#2563eb"; background: "#ffffff"; }
//         dark  { primary: "#60a5fa"; background: "#0b1120"; }
//     }
//     Coloring {
//         dark  { card { border: "#26263a"; } tabs { active: "#818cf8"; } }
//     }
// }
